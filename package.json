{
  "name": "openbenefacts",
  "version": "1.0.0",
  "description": "Modern transparency platform for Ireland's nonprofit sector — a replacement for Benefacts.ie",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-sitemap.cjs && vite build",
    "build:sitemap": "node scripts/generate-sitemap.cjs",
    "preview": "vite preview",
    "data:fetch": "python3 scripts/data-pipeline.py",
    "data:enrich": "python3 scripts/ai-enrichment.py",
    "db:setup": "echo 'Run scripts/supabase-setup.sql in your Supabase SQL editor'"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^0.469.0",
    "pdf-parse": "^1.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.0"
  }
}
